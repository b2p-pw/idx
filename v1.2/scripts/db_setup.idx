# Instruction Definition eXchange (IDX) [CoffeScript]
# db_setup.idx - Script de configuração do banco de dados.

idx   = 1.2
allow = term, sys, net    # Herdado do script que fez a chamada. O pai deve ter as mesmas ou mais permissões.

on_fail: recovery

fn setup name, port:
    term.print "Iniciando configuração do DB: " cyan "{name}" reset " na porta " cyan "{port}"
    
    match sys.check_service "postgresql":
        {res} == "running": 
            term.print green "Serviço PostgreSQL ativo."
        {res} == "stopped": 
            term.print yellow "PostgreSQL parado. Tentando iniciar..."
            sys.start_service "postgresql"
        {err}: term.throw "Serviço de banco de dados não encontrado: {err.message}"

    # Definição de valores de saida do comando, seguido de um "mecth".
    # Como o comando retorna múltiplos valores, eles são definidos como "{res, 0}" e "{res, 1}",
    # e/ou variáveis nomeadas, como "{ping}" e "{hopes}".
    ping, hopes = match net.ping "localhost:{port}":
        {res, 0} < 200: 
            term.print green "Porta {port} acessível."
            # Retorno múltiplos valores.
            return {ping}, {hopes}
        {res, 0} >= 200 or {err}: term.throw "Porta {port} está bloqueada ou em uso."

fn retry name, port, attempts:
    term.print yellow "Tentativa de reconexão: " reset "{attempts} restantes..."
    try:
        setup {name}, {port}
    catch:
        if {attempts} > 0: retry {name}, {port}, {attempts} - 1
        else: term.throw "Falha ao configurar o DB após múltiplas tentativas."

fn rollback:
    term.print nl red "Executando Rollback de Banco de Dados..."
    sys.write "ROLLBACK COMPLETE" to "{log}/db_recovery.log"

fn recovery:
    term.print nl red "Falha Crítica no módulo DB!"
    term.print red "O módulo db_setup não conseguiu se recuperar: {err.message}"
    exit 1