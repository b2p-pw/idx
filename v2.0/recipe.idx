# Instruction Definition eXchange (IDX) [CoffeScript]
# recipe.idx - Script principal de instalação do pacote "my-package".

idx   = 2.0                    # Versão do formato IDX.
allow = term, sys, net, b2p    # Permissões para usar módulos específicos. O pai deve ter as mesmas ou mais permissões.

on_fail: "scripts/fail_script.idx"    # Script a ser executado em caso de falha.
on_interrupt: cancel_install          # Função a ser chamada se o usuário interromper o script .

# Metadados do pacote (exemplo especifico de uma receita para o b2p).
package         = "my-package"
recipe_version  = "1.5.0"
flavor          = "vanilla"
b2p_requirement = ">=1.31.0"
target          = "b2p"
kernel          = "windows-nt"

# Importação de scripts auxiliares.
use "scripts/db_setup.idx" >= 1.2 as db 

plugins = "audio.dll", "imgs.dll", "net.dll"

# Definição de constantes para uso no script.
const BIN_URL = "https://repo.com/app.zip"
const DB_NAME = "users_db"
const DB_PORT = "5432"

# Bloco de try-catch para gerenciar erros e garantir a robustez do processos.
try:
    # Bloco de execção em paralelo para otimizar o processos.
    parallel:
        db.setup port = {DB_PORT, number}, name = {DB_NAME}    # Chamada de função de um script importado usando valores nomeados e convertidos. 
            into: show_ping                                    # Pipe para um call para exibir o ping após a configuração do DB.

        # Expanão da lista como argumentos individuais.
        b2p.register {plugins, *} as parallel

        # Bloco de passos, saido do paralelo para garantir a ordem de execução.
        step:
            # Chamada de função local.
            extract {BIN_URL}

            # Outro bloco de excução paralela.
            parallel:
                # Bloco de "match" que roda o comando e espera uma saida,
                # sendo um resultado ("res" em caso de saida simples ou "{res, 0}", "{res, 1}"... em caso de saida múltipla)
                # ou um erro ("{err}").
                match sys.version "{b2p.bin}/app.exe":
                    {res} >= 10.0: term.print green "Versão detectada:" reset "{res}"
                    {res} >= 5.0:  term.print yellow "Versão desatualizada: " reset "{res}"
                    {res} < 5.0:   term.throw "Versão defasada: " gray "{res}"
                    {err} == 1:    term.throw "Binário corrompido."
                    {err} == 5:    term.throw "Acesso Negado (UAC)."
                    {err}:         term.throw "Erro Fatal no Binário: {err.message}"
                
                # Loop percorre um array em execução paralela.
                for dll in "auth.dll", "logs.dll" as parallel:
                    sys.copy "{sys.TEMP}/{dll}" to "{b2p.bin_path}/dlls/"

        # Outro bloco de passos, que roda em paralelo a chamada de função e ao outro bloco de passos.
        step:
            env_type = "prod" if {sys.env} == "production" else "dev"
            sys.write "Config: 'Value'" to "{b2p.conf}/{env_type}/settings.ini"

# Bloco de tartamentos de erros especifico de todo o import "db" e suas funções.
catch db:
    term.print "Falha no DB: {err.message}"
    # Chamada de função de um script importado usando usando valores posicionados.
    db.retry {DB_NAME}, {DB_PORT} as number, 3

# Bloco de tratamento de erros apenas para as funções "copy", "write", "unzip" e "move".
catch sys.copy, sys.write, sys.unzip, sys.move:
    sys.write "Erro de I/O: {err.message}" to "{log}/io.log"
    term.print nl red "Erro de I/O: {err.message}"
    term.print yellow "Iniciando rollback de arquivos..."
    run "io_rollback.idx"
    exit 1

# Bloco de tratamento de erros genérico para qualquer outro erro não tratado anteriormente.
catch:
    term.print nl red "Erro fatal desconhecido: {err.message}"
    exit 1

# Definição de função local simples.
fn extract url as string:
    net.download {url} to "{sys.TEMP}/app.zip"
    sys.unzip "{sys.TEMP}/app.zip" to "{sys.TEMP}"
    sys.move "{sys.TEMP}/app.exe"  to "{b2p.bin_path}/app.exe"

# Definição de função de interrupção.
fn cancel_install:
    term.print nl "Instalação cancelada pelo usuário."
    term.print yellow "Rollback iniciado em segundo plano."
    # Chamada de funções de um script sem importação.
    run "io_rollback.idx" as parallel:
        do: remove_bin 
        do: remove_plugins
        do: remove_config
    exit 0

# Definição de função com entrada multipla.
fn show_ping ping, hopes as number:
    term.print "Ping para DB: " cyan "{ping}ms" reset " com " cyan "{hopes} saltos" reset "."