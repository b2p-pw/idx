# Instruction Definition eXchange

@{idx_version}: 1
@{idx_scope}: [package]
@{package}: my-package
@{version}: 1.0.0
@{target}: b2p
@{kernel}: windows-nt

driver: B2P ; "b2p"
driver: WINDOWS_NT ; "win"
driver: CURL ; "net"

${binary}: https://repo.com/app.zip
${config}: https://repo.com/setup.conf

(main):
    $plugins: ["auth.dll" , "logs.dll" , "api.dll"]
    ${environment}: ""

    on_error: (error)!

    call: "./scripts/db_setup.idx" ; (setup) ; $db_name: "users_db" , $port: 5432

    jump: (extract)

    if: ${ENV} != production
        then:
            ${environment}: "dev"
        else:
            ${environment}: "prod"

    win.check_version: ${BIN}/app.exe | $app_version
        match: $EXIT_CODE
            0:
                print: "Sucesso!"
            1:
                print: "Erro Geral: O binário está corrompido."
                error: (error)
            5:
                print: "Erro de Permissão: Rode como Administrador."
                error: (error)
            *:
                print: "Erro desconhecido: $EXIT_CODE"
                error: (error)

    win.print: "Versão detectada: $app_version"

    win.write: "Config: \"Value\"" > $CONF/${environment}/settings.ini
    win.write: $config > $CONF/${environment}/config.ini
    win.permission: $CONF/${environment}/config.ini ; read-only

    for: $p in $plugins
        win.copy: ${TEMP}/$p ; $BIN/plugins/$p

(extract):
    net.download: ${binary} ; ${TEMP}/app.zip
    win.extract: ${TEMP}/app.zip ; ${TEMP}
    win.copy: ${TEMP}/app.exe ; $BIN/app.exe

(error):
    win.write: "Erro na execução do pacote ${package}" >> $LOG/error.log
    stop: 1