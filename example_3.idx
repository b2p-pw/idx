# Instruction Definition eXchange (IDX) [coffescript]

idx: 3.2 
allow: [term, sys, net, b2p]
on_fail: "logs/error.idx"

package: "my-package"
version: "1.2.0"
kernel: "windows-nt"

use "./db_setup" as db

const BIN_URL = "https://repo.com/app.zip"

try: 
    db.setup name: "users_db", port: 5432

    parallel:
        extract BIN_URL

        env_type = "prod" if sys.env == "production" else "dev"

        match sys.version "{b2p.bin}/app.exe":
            ok(ver) => term.print "Versão detectada: {ver}"
            err(1)  => throw "Binário corrompido"
            err(5)  => throw "Acesso Negado (UAC)"
            *       => throw "Erro Fatal no Binário"

        sys.write "Config: 'Value'" -> "{b2p.conf}/{env_type}/settings.ini"

    for plugin in ["auth.dll", "logs.dll"] as parallel:
        sys.copy "{sys.TEMP}/{plugin}" -> "{b2p.bin}/plugins/"

catch err: 
    "Erro: {err} no Pkg: {package}" -> "{b2p.log}/error.log"
    exit 1

fn extract url:
    net.download url -> "{sys.TEMP}/app.zip"
    sys.unzip "{sys.TEMP}/app.zip" -> "{sys.TEMP}"
    sys.move "{sys.TEMP}/app.exe"  -> "{b2p.bin}/app.exe"