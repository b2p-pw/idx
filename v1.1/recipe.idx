// Instruction Definition eXchange (IDX) [C#]

@IDX_VERSION = 1.1
@IDX_SCOPE = [package]

@PACKAGE = "my-package"
@RECIPE_VERSION = "1.0.0"
@B2P_REQUIREMENT = ">=1.0.0"
@TARGET = "b2p"
@KERNEL = "windows-nt"

resource [term, sys, win, net]

from "./db_setup" import db

const BIN_URL = "https://repo.com/app.zip"

main(env: ENV) {
    try {
        db.setup(name: "users_db", port: 5432)

        extract(url: BIN_URL)

        env_type = (sys.env(env) == "production") ? "prod" : "dev"

        match win.version("${b2p.bin}/app.exe") {
            ok(ver) => term.print("Versão: {ver}"),
            err(1)  => throw "Binário corrompido",
            err(5)  => throw "Requer Admin",
            *       => throw "Erro desconhecido"
        }

        win.write("Config: 'Value'") -> "{b2p.conf}/{env_type}/settings.ini"
        win.read_only("{b2p.conf}/{env_type}/config.ini")

        for plugin in ["auth.dll", "logs.dll", "api.dll"] {
            win.copy("{win.TEMP}/{plugin}", "{b2p.bin}/plugins/")
        }
    } catch (err) {
        win.write("Erro: {err}; Pkg: {PACKAGE}") >> "{b2p.log}/error.log"
        exit 1
    }
}

extract(url: String) {
    net.download(url, "{win.TEMP}/app.zip")
    win.unzip("{win.TEMP}/app.zip", "{win.TEMP}")
    win.copy("{win.TEMP}/app.exe", "{b2p.bin}/app.exe")
}